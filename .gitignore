# Rust / Cargo
/target
**/*.rs.bk

# Node / frontend
node_modules
dist
.vite

# Tauri build output
src-tauri/target
src-tauri/gen

# Editor / OS
.DS_Store
*.log
.env
.env.*
!.env.example

# Hermit's local package install dir (extracted toolchains, ~hundreds of MB).
# Regenerated by `hermit` on any machine — never commit it.
.hermit/

# Hermit's bin/ (toolchain symlinks + activate scripts) IS committed — it pins the
# toolchain, and `hermit` repopulates .hermit/ from it. Force it past any global
# `bin/` ignore the user may have.
!/bin/
!/bin/**
